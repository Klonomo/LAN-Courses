<?xml version="1.0" encoding="utf-8"?>
<lesson id="lesson_gram_15_01" title="Bedingungssätze mit si">
    <body><![CDATA[<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body { font-family: sans-serif; padding: 8px 4px 24px; line-height: 1.55; color: #222; }
.section-title { font-size: 1.35em; font-weight: bold; margin-bottom: 12px; }
.section-content p { margin: 10px 0; }
.examples { margin: 8px 0; padding: 8px 10px; background: #f4f4f4; border-radius: 6px; }
.examples div { margin: 4px 0; }
.fr { font-weight: 500; }
.de { color: #555; font-style: italic; }
.ipa { color: #777; font-size: 0.9em; margin-left: 6px; }
.attention { border-left: 4px solid #ff9800; padding: 8px 12px; margin: 12px 0; background: #fff8ef; }
h3 { margin-top: 18px; margin-bottom: 8px; font-size: 1.1em; }
ul, ol { padding-left: 20px; }
li { margin: 8px 0; }
table { border-collapse: collapse; width: 100%; margin: 12px 0; }
th, td { border: 1px solid #ddd; padding: 6px 8px; text-align: left; }
