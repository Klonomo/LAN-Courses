<lesson id="lesson_gram_07_02" title="Die unverbundenen Personalpronomen (moi, lui)">
    <body><![CDATA[<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
