<lesson id="lesson_gram_13_06" title="Verb + pour">
    <body><![CDATA[<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body { font-family: sans-serif; padding: 8px 4px 24px; line-height: 1.55; color: #222; }
