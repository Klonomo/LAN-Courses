<lesson id="lesson_gram_13_12" title="Verb + de + Infinitiv">
    <body><![CDATA[<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
