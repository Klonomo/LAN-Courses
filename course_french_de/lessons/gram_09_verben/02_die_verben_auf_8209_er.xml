.attention { border-left: 4px solid #ff9800; padding: 8px 12px; margin: 12px 0; background: #fff8ef; }
h3 { margin-top: 18px; margin-bottom: 8px; font-size: 1.1em; }
ul, ol { padding-left: 20px; }
