<lesson id="lesson_gram_09_02" title="Die Verben auf &amp;#8209;er">
    <body><![CDATA[<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
