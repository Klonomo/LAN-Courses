<lesson id="lesson_gram_08_04" title="Fragen mit que">
    <body><![CDATA[<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
body { font-family: sans-serif; padding: 8px 4px 24px; line-height: 1.55; color: #222; }
.section-title { font-size: 1.35em; font-weight: bold; margin-bottom: 12px; }
